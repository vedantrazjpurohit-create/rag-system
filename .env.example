# Optional: Grok LLM answers via xAI (https://console.x.ai)
XAI_API_KEY=
XAI_MODEL=grok-4.5
XAI_BASE_URL=https://api.x.ai/v1

# API CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production: your Vercel URL (also added to CORS automatically)
FRONTEND_URL=

# Allow *.vercel.app preview deployments (default true)
ALLOW_VERCEL_PREVIEWS=true

# Render sets PORT automatically
PORT=8000

# HuggingFace model cache
HF_HOME=.hf_cache