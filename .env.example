# Optional: Grok LLM answers via xAI (https://console.x.ai)
XAI_API_KEY=
XAI_MODEL=grok-4.5
XAI_BASE_URL=https://api.x.ai/v1

# API CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production: your Vercel URL (also added to CORS automatically)
FRONTEND_URL=

# Allow Vercel preview deployments (default false — set true only if needed)
ALLOW_VERCEL_PREVIEWS=false
# Optional: restrict previews to one Vercel project slug
VERCEL_PREVIEW_PROJECT=

# API auth (set in production — read by FastAPI and Next.js /api-proxy route)
RAG_API_KEY=
RAG_ADMIN_KEY=
# Next.js proxy target (local dev: http://127.0.0.1:8000)
API_PROXY_TARGET=http://127.0.0.1:8000

# Tenant header X-Tenant-Id required when RAG_API_KEY is set (UUID recommended)

# Trust X-Forwarded-For only behind a known reverse proxy
TRUST_PROXY_HEADERS=false

# PDF extraction limits
MAX_PDF_PAGES=200
MAX_EXTRACTED_CHARS=500000
PDF_PARSE_TIMEOUT_S=30
PDF_PARSE_IN_PROCESS=false

# Returned context size (full text only when include_full_context=true)
CONTEXT_EXCERPT_CHARS=320

# Render sets PORT automatically
PORT=8000

# HuggingFace model cache
HF_HOME=.hf_cache