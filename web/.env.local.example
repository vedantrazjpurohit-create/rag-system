# Local Next.js full stack (recommended) — no Python required:
#   cd web && npm run dev
# Leave NEXT_PUBLIC_API_URL unset so the app uses same-origin /api-proxy.

# Optional: talk to local Python API instead
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Optional LLM answers (xAI Grok)
# XAI_API_KEY=
# XAI_MODEL=grok-4.5

# Public demo uses X-Tenant-Id isolation only (not real login).
# REQUIRE_API_KEY=true   # require RAG_API_KEY on every API call
# RAG_API_KEY=
# RAG_ADMIN_KEY=         # required for /demo/seed and /eval when set
# FRONTEND_URL=https://your-app.vercel.app
# CORS_ORIGINS=http://localhost:3000
# ALLOW_VERCEL_PREVIEWS=true
# ALLOW_FULL_CONTEXT=true  # only if you need full chunk text in API responses

# PDF / OCR — defaults support long course notes (500 pages)
# MAX_PDF_PAGES=500
# MAX_OCR_PAGES=500
# MAX_PDF_BYTES=52428800
# MAX_UPLOAD_BYTES=52428800
# MAX_EXTRACTED_CHARS=5000000
# MIN_PDF_TEXT_CHARS=40
# PDF_PARSE_TIMEOUT_MS=280000
