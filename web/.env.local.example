# --- Local dev ---
# Browser hits the API directly (or leave unset and use npm run dev with proxy).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
API_PROXY_TARGET=http://127.0.0.1:8000

# --- Vercel production (Project → Settings → Environment Variables) ---
# Do NOT set NEXT_PUBLIC_API_URL on Vercel — the browser should use same-origin /api-proxy.
# API_PROXY_TARGET=https://YOUR-RENDER-SERVICE.onrender.com
# RAG_API_KEY=same-as-render
# RAG_ADMIN_KEY=same-as-render
