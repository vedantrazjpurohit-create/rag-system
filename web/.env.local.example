# --- Free LLM (recommended for students) ---
# Groq free tier: https://console.groq.com  (create key, paste below)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter free models: https://openrouter.ai
# OPENROUTER_API_KEY=
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Or any OpenAI-compatible endpoint:
# LLM_API_KEY=
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# Paid options (optional):
# XAI_API_KEY=
# XAI_MODEL=grok-4.5
# OPENAI_API_KEY=

# Local Next.js full stack — leave NEXT_PUBLIC_API_URL unset.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Public demo uses X-Tenant-Id isolation only (not real login).
# REQUIRE_API_KEY=true
# RAG_API_KEY=
# RAG_ADMIN_KEY=
# FRONTEND_URL=https://your-app.vercel.app
# CORS_ORIGINS=http://localhost:3000
# ALLOW_VERCEL_PREVIEWS=true

# PDF / OCR — long course notes
# MAX_PDF_PAGES=500
# MAX_OCR_PAGES=500
# MAX_PDF_BYTES=157286400
# MAX_UPLOAD_BYTES=157286400
